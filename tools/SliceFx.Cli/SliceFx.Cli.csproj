<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>SliceFx.Cli</RootNamespace>
    <AssemblyName>SliceFx.Cli</AssemblyName>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>slicefx</ToolCommandName>
    <PackageId>SliceFx.Cli</PackageId>
    <PackageOutputPath>$(MSBuildThisFileDirectory)nupkg</PackageOutputPath>
    <Description>CLI scaffolding tool for the SliceFx vertical slice framework.</Description>
    <PackageTags>slicefx;slice;cli;scaffolding;dotnet-tool;vertical-slice;vertical-slice-architecture;aspnet-core;minimal-api</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.11.0" />
    <PackageReference Include="MSBuild.StructuredLogger" Version="2.3.204" />
    <PackageReference Include="System.CommandLine" Version="2.0.8" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\..\src\Shared\SliceRouteManifestSchema.cs" Link="Shared\SliceRouteManifestSchema.cs" />
  </ItemGroup>

</Project>
