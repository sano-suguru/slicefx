<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>Slice.Cli</RootNamespace>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>slice</ToolCommandName>
    <PackageId>Slice.Cli</PackageId>
    <PackageOutputPath>$(MSBuildThisFileDirectory)nupkg</PackageOutputPath>
    <Description>CLI scaffolding tool for the Slice vertical slice framework.</Description>
    <PackageTags>slice;cli;scaffolding;dotnet-tool;vertical-slice</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.CommandLine" Version="2.0.8" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\..\src\Shared\SliceRouteManifestSchema.cs"
             Link="Shared\SliceRouteManifestSchema.cs" />
  </ItemGroup>

</Project>
